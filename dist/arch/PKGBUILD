# Maintainer: Your Name <your.email@example.com>

pkgname=cathode
pkgver=0.1.0
pkgrel=1
pkgdesc='A retro CRT terminal emulator with scanline shader'
arch=('x86_64')
url='https://github.com/n0zoberi/cathode'
license=('MIT')
options=('!debug')
depends=(
  'gtk4'
  'libadwaita'
  'vte4'
  'libepoxy'
  'cairo'
  'glib2'
)
makedepends=('meson' 'ninja' 'pkgconf' 'gettext')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

_srcdir="Cathode-$pkgver"

build() {
  cd "$_srcdir"
  meson setup --prefix /usr --buildtype=plain \
    -D b_pie=true build .
  meson compile -C build
}

package() {
  DESTDIR="$pkgdir" meson install -C "$_srcdir/build"
}
